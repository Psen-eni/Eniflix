{% extends 'base.html.twig' %}

{% block title %} {{ parent() }} - Catalogue{% endblock %}

{% block body %}
    <h2>Catalogue</h2>

<section>
    {% if page > 1 %}
        <a href="{{ path('list', {'page' : page -1}) }}">Page précédente</a>&nbsp;
    {% endif %}
    {% if page < totalPages %}
        <a href="{{ path('list', {'page' : page +1}) }}">Page suivante</a>&nbsp;
    {% endif %}
</section>

    <table>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Status</th>
                <th>Popularity</th>
                <th>First Air Date</th>
                <th>Last Air Date</th>
            </tr>
        {%  for serie in series %}

            <tr>
                <td>{{ serie.id }}</td>
                <td>{{ serie.name }}</td>
                <td>{{ serie.status }}</td>
                <td>{{ serie.vote }}</td>
                <td>{{ serie.popularity }}</td>
                <td>{{ serie.firstAirDate|date('d/m/Y') }}</td>
                <td>{{ serie.lastAirDate|date('d/m/Y') ? '' }}</td>
            </tr>
        {% endfor %}
    </table>

{% endblock %}
